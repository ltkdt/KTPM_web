<Window x:Class="HRMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HRMonitor"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Theo dõi bệnh nhân" Height="700" Width="1100" WindowStartupLocation="CenterScreen" Background="#F3F2F1" FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F2F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#8A8886"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#323130"/>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="SubHeaderLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#323130"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Login View -->
        <Grid x:Name="LoginGrid" Visibility="Visible" Background="White" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <TextBlock x:Name="LoginTitleText" Text="Đăng nhập Bác sĩ" Style="{StaticResource HeaderLabel}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <TextBlock Text="Tài Khoản" Margin="0,0,0,5" Foreground="#605E5C"/>
                <TextBox x:Name="IdTextBox" Margin="0,0,0,15"/>
                
                <TextBlock Text="Mật khẩu" Margin="0,0,0,5" Foreground="#605E5C"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20" Padding="8" BorderBrush="#8A8886" BorderThickness="1"/>
                
                <Button Content="Đăng nhập" Style="{StaticResource PrimaryButton}" Click="Submit_Click"/>
                <Button x:Name="RoleToggleBtn" Content="Đăng nhập Quản trị viên" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0" Click="RoleToggle_Click"/>
                <TextBlock x:Name="LoginErrorText" Foreground="#A4262C" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed" Text="ID hoặc mật khẩu không đúng."/>
            </StackPanel>
        </Grid>

        <!-- Dashboard View -->
        <Grid x:Name="DashboardGrid" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Area: Patient List or Blank Record Panel -->
            <Grid Grid.Column="0" x:Name="LeftAreaGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="DoctorListRow" Height="0"/>
                </Grid.RowDefinitions>
                
                <!-- Patient List Grid -->
                <Grid x:Name="PatientListGrid" Grid.Row="0" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Padding="30,20,30,0">
                        <StackPanel>
                            <TextBlock Text="Danh sách bệnh nhân" Foreground="#323130" FontSize="28" FontWeight="SemiBold"/>
                            <WrapPanel x:Name="AdminDashboardPanel" Visibility="Collapsed" Margin="0,15,0,5">
                                <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,10,0"><StackPanel><TextBlock Text="Bệnh nhân" Foreground="#605E5C"/><TextBlock x:Name="TotalPatientsText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                                <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,10,0"><StackPanel><TextBlock Text="Bác sĩ" Foreground="#605E5C"/><TextBlock x:Name="TotalDoctorsText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                                <Border Background="White" CornerRadius="6" Padding="12" Margin="0,0,10,0"><StackPanel><TextBlock Text="Thiết bị ECG hoạt động" Foreground="#605E5C"/><TextBlock x:Name="ActiveDevicesText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                                <Border Background="#FFF4CE" CornerRadius="6" Padding="12"><StackPanel><TextBlock Text="Ca chờ tư vấn" Foreground="#605E5C"/><TextBlock x:Name="PendingConsultationsText" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="PatientListView" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="20" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="PatientListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="6" Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="#323130"/>
                                            <TextBlock Text="{Binding GenderAgeText}" FontSize="14" Foreground="#605E5C" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Doctor List Grid (Admin only) -->
                <Grid x:Name="DoctorListGrid" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Padding="30,20,30,0">
                        <TextBlock Text="Danh sách bác sĩ" Foreground="#323130" FontSize="28" FontWeight="SemiBold"/>
                    </Border>

                    <ListView x:Name="DoctorListView" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="20" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="DoctorListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="6" Padding="20">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" FontSize="18" FontWeight="SemiBold" Foreground="#323130"/>
                                            <TextBlock Text="{Binding Specialty}" FontSize="14" Foreground="#605E5C" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Record List Panel -->
                <Grid x:Name="RecordListGrid" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="White" Margin="20">
                    <Grid.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Grid.Effect>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="20">
                        <Button Content="← Quay lại danh sách bệnh nhân" Style="{StaticResource SecondaryButton}" Click="BackToPatients_Click"/>
                        <TextBlock Text="Bản ghi ECG" Style="{StaticResource HeaderLabel}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1" Margin="20,0,20,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ID" FontWeight="Bold" Foreground="#323130" Grid.Column="0" Margin="15,0,0,0"/>
                        <TextBlock Text="Tên bản ghi" FontWeight="Bold" Foreground="#323130" Grid.Column="1"/>
                        <TextBlock Text="Thao tác" FontWeight="Bold" Foreground="#323130" Grid.Column="2" HorizontalAlignment="Center"/>
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#E1DFDD" BorderThickness="0,0,0,1" Margin="20,25,20,0"/>

                    <ListView x:Name="RecordListView" Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="20,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,15"/>
                                <Setter Property="BorderBrush" Value="#E1DFDD"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Id}" VerticalAlignment="Center" Grid.Column="0" Foreground="#323130" Margin="15,0,0,0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="#323130" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Date}" Foreground="#8A8886"/>
                                    </StackPanel>
                                    <Button Content="Xem" Style="{StaticResource PrimaryButton}" Grid.Column="2" Padding="15,6" Click="ViewRecordDetail_Click" Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Grid.Row="3" BorderBrush="#E1DFDD" BorderThickness="0,1,0,0" Padding="20">
                        <Grid>
                            <Button Content="Trước" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Padding="15,6"/>
                            <TextBlock Text="Trang 1 / 2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#605E5C"/>
                            <Button Content="Sau" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Padding="15,6"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- Right Area: Profile Panel -->
            <Border x:Name="RightProfilePanel" Grid.Column="1" Background="#FAF9F8" BorderBrush="#E1DFDD" BorderThickness="1,0,0,0">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <Button Content="Đăng xuất" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" Click="Logout_Click"/>
                        <TextBlock Text="Thông tin chi tiết" Style="{StaticResource HeaderLabel}"/>
                    </DockPanel>
                    
                    <StackPanel x:Name="ProfileDetailsPanel" Grid.Row="1" Visibility="Collapsed">
                        <Border Background="White" CornerRadius="8" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Họ tên" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfileName" Grid.Column="1" Foreground="#323130" FontSize="16" TextWrapping="Wrap"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Tuổi" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfileAge" Grid.Column="1" Foreground="#323130" FontSize="16"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Giới tính" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfileGender" Grid.Column="1" Foreground="#323130" FontSize="16"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Số điện thoại" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfilePhone" Grid.Column="1" Foreground="#323130" FontSize="16"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Email" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProfileEmail" Grid.Column="1" Foreground="#323130" FontSize="16" TextWrapping="Wrap"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Địa chỉ" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                    <TextBlock x:Name="ProfileAddress" Grid.Column="1" Foreground="#323130" FontSize="16" TextWrapping="Wrap"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,15" x:Name="DoctorAssignmentGrid" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bác sĩ phụ trách" Foreground="#605E5C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="AssignDoctorComboBox" Grid.Column="1" DisplayMemberPath="FullName" SelectedValuePath="Id" SelectionChanged="AssignDoctorComboBox_SelectionChanged" />
                                </Grid>
                                
                                <Button x:Name="ViewRecordsFromProfileBtn" Content="Xem bản ghi" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" HorizontalAlignment="Left" Click="ViewRecordFromProfile_Click"/>
                                <Button x:Name="DeleteAccountBtn" Content="Xóa tài khoản" Style="{StaticResource PrimaryButton}" Background="#A4262C" Margin="0,10,0,0" HorizontalAlignment="Left" Click="DeleteAccountBtn_Click" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock x:Name="EmptyProfileText" Grid.Row="1" Text="Chọn một bệnh nhân để xem hồ sơ." Foreground="#A19F9D" HorizontalAlignment="Center" Margin="0,50,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <!-- Record Detail Modal -->
        <Grid x:Name="RecordDetailModal" Visibility="Collapsed" Panel.ZIndex="200" Background="#99FFFFFF">
            <Border Background="White" Margin="40" CornerRadius="8" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock x:Name="RecordDetailTitle" Text="ecg_record.json" HorizontalAlignment="Center" Style="{StaticResource SubHeaderLabel}"/>
                        <Button Content="✕" Background="Transparent" Foreground="#605E5C" FontSize="20" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseModal_Click" Padding="5"/>
                    </Grid>

                    <!-- Indicators -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="Nhịp tim (bpm)" Foreground="#605E5C" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBox x:Name="HrTextBox" IsReadOnly="True" Width="100" TextAlignment="Center" FontWeight="SemiBold" Foreground="#323130" Background="#FAFAFA" Text="60.3"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="RMSSD (ms)" Foreground="#605E5C" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBox x:Name="RmssdTextBox" IsReadOnly="True" Width="100" TextAlignment="Center" FontWeight="SemiBold" Foreground="#323130" Background="#FAFAFA" Text="35.8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Plot -->
                    <Border Grid.Row="2" BorderBrush="#E1DFDD" BorderThickness="1" Margin="0,0,0,20">
                        <ScottPlot:WpfPlot x:Name="EcgPlot" />
                    </Border>

                    <!-- Notes -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Triệu chứng" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <TextBox x:Name="ComplaintTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="80" IsReadOnly="True" Background="#FAFAFA" Text="Cảm thấy mệt và hụt hơi sau khi chạy liên tục khoảng 20 phút, kèm theo nhịp tim tăng nhanh hơn bình thường."/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <TextBlock Text="Nhận xét" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <TextBox x:Name="FindingsTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Text="Nhịp tim tăng (sinus tachycardia) sau gắng sức, không ghi nhận bất thường rõ rệt về ST-T. Không có dấu hiệu thiếu máu cơ tim cấp. Nhịp đều, trục tim bình thường."/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Phác đồ điều trị" Foreground="#605E5C" Margin="0,0,0,5"/>
                            <TextBox x:Name="TreatmentTextBox" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Text="Khuyến nghị nghỉ ngơi và theo dõi thêm. Uống đủ nước, điều chỉnh cường độ tập luyện phù hợp. Nếu triệu chứng tái diễn hoặc kèm đau ngực/chóng mặt, cần tái khám để làm thêm các xét nghiệm (ECG gắng sức, siêu âm tim)."/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Submit Button -->
                    <Button Grid.Row="4" Content="Gửi phản hồi" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0,20,0,0" Padding="30,10" Click="SubmitFeedback_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
